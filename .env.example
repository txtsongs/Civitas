# Civitas — environment variables
# Copy this file to .env and fill in real values. NEVER commit .env.

# XDC Apothem testnet RPC endpoint (default works; override if you use a private node)
APOTHEM_RPC_URL=https://erpc.apothem.network

# Private key of the wallet that will deploy contracts to Apothem.
# 64 hex chars, no 0x prefix. Fund this wallet with testnet TXDC from the Apothem faucet
# before deploying: https://faucet.apothem.network/
DEPLOYER_PRIVATE_KEY=
